# Supply-chain hardening
# Dep install/postinstall scripts are blocked by default in pnpm 10 and only
# run for packages listed in pnpm.onlyBuiltDependencies (in package.json).
# Our own root scripts still run.

# Refuse to install packages published less than this many minutes ago.
# 1440 = 24h — gives time for malicious uploads to be detected and yanked.
minimum-release-age=1440

# Don't silently install if engines (node/pnpm) don't match.
engine-strict=true

# Don't auto-install peer deps we never asked for.
auto-install-peers=true

# Use npm-style flat node_modules layout. Required for MUI's Theme module
# augmentation and @sentry/react's re-exports to resolve correctly under
# TypeScript. We lose pnpm's strict-tree (phantom-dep detection) but keep
# all the supply-chain wins (script blocking, min release age, patches).
node-linker=hoisted
